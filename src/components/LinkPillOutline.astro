---
import LinkPill from "#src/components/LinkPill.astro";
import type { ComponentProps } from "astro/types";

type Props = ComponentProps<typeof LinkPill>;
---

<LinkPill {...Astro.props}><slot /></LinkPill>

<style lang="scss">
  a {
    color: var(--color-a);
    &:hover {
      color: var(--color-a-hover);
    }
    &:is(:active, :focus-visible) {
      color: var(--color-a-active);
    }
    &:focus-visible {
      outline-color: var(--color-a-hover);
    }
  }
</style>
