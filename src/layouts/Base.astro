---
import { Font } from "astro:assets";
import BaseHead from "#src/components/BaseHead.astro";
import type { ComponentProps } from "astro/types";

type Props = ComponentProps<typeof BaseHead>;
---

<html lang="en" prefix="og: https://ogp.me/ns#">
  <head>
    <BaseHead {...Astro.props} />
    <slot name="head" />
    <Font cssVariable="--font-inter" preload />
  </head>

  <body>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  :root {
    --color: #ddd;
    --color-2: #c5c8c9;
    --color-3: #a5a8a9;
    --color-4: #707476;
    --color-a: #00af9f;
    --color-a-active: #07e3c3;
    --color-a-hover: #03cfb0;
    --color-bg: #000;
    --color-bg-transparent: #000e;
    --color-border: #303335;
    --color-highlight: #1d8;
    --color-input: #1a1c1c;
    --color-input-active: #2f3333;
    --color-input-hover: #272a2a;
    --color-input-outline: #858889;
    --color-premium: #ffce00;
    --color-valid: #0f8;
    color-scheme: dark light;
  }

  html {
    height: 100%;
    scroll-behavior: smooth;
    scrollbar-color: var(--color-4) transparent;
    scrollbar-gutter: stable both-edges;
    scrollbar-width: thin;
  }

  body {
    display: flex;
    flex-direction: column;
    margin: 0;
    background: var(--color-bg);
    min-height: 100%;
    color: var(--color-2);
    line-height: 1.5;
    font-family: var(--font-inter);
    -webkit-tap-highlight-color: transparent; // Remove tap highlight in webkit based browsers
    &:has(dialog[open]) {
      overflow: hidden;
    }
  }

  a {
    display: inline-flex;
    align-items: center;
    vertical-align: top;
    gap: 0.5em;
    transition-duration: 0.15s;
    transition-property: color, text-decoration-color, text-underline-offset;
    color: var(--color-a);
    text-decoration-color: transparent;
    text-underline-offset: 0.375em;
    white-space: nowrap;
    &:hover {
      color: var(--color-a-hover);
      text-decoration-color: currentcolor;
      text-underline-offset: 0.125em;
    }
    &:active {
      color: var(--color-a-active);
    }
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--color);
    font-weight: 400;
    line-height: 1.375;
  }

  ol,
  ul {
    display: grid;
    gap: 0.5em;
    padding-inline-start: 1.25em;
    color: var(--color-3);
    > li {
      &::marker {
        color: var(--color-highlight);
      }
    }
  }

  strong {
    color: var(--color);
    font-weight: 500;
  }

  @media (width <= 40em) {
    // HEADER hamburguer
    body:has(.checkbox-hide-scrollbar:checked) {
      overflow: hidden;
    }
  }
</style>
