---
import { Icon } from "astro-icon/components";
import emails from "#shared/email.json";
import MainLayout from "#src/layouts/Main.astro";
import LinkNext from "#src/components/LinkNext.astro";

const iconDimension = "1.375em";
const iconSendDimension = "1.25em";
---

<MainLayout>
  <h1>Contact</h1>

  <div class="container-contact">
    <!--<article class="article-contact">
      <h2 class="article-contact-title"><Icon name="user/issue" size={iconDimension} />Account or profile issues</h2>
      <p><Icon name="email" size={iconDimension} />{emails.issues}</p>
      <LinkNext href={`mailto:${emails.issues}`}><Icon name="send" size={iconSendDimension} />Send an email</LinkNext>
    </article>
    <article class="article-contact">
      <h2 class="article-contact-title"><Icon name="feedback" size={iconDimension} />Feedback</h2>
      <p><Icon name="email" size={iconDimension} />{emails.feedback}</p>
      <LinkNext href={`mailto:${emails.feedback}`}><Icon name="send" size={iconSendDimension} />Send an email</LinkNext>
    </article>
    <article class="article-contact">
      <h2 class="article-contact-title"><Icon name="business" size={iconDimension} />Business</h2>
      <p><Icon name="email" size={iconDimension} />{emails.business}</p>
      <LinkNext href={`mailto:${emails.business}`}><Icon name="send" size={iconSendDimension} />Send an email</LinkNext>
    </article>
    <article class="article-contact">
      <h2 class="article-contact-title"><Icon name="bug" size={iconDimension} />Report a bug</h2>
      <p><Icon name="email" size={iconDimension} />{emails.bugs}</p>
      <LinkNext href={`mailto:${emails.bugs}`}><Icon name="send" size={iconSendDimension} />Send an email</LinkNext>
    </article>-->
    <article class="article-contact">
      <h2 class="article-contact-title"><Icon name="pencil" size={iconDimension} />General</h2>
      <!--<p>
        <Icon name="info" size={iconDimension} />If none of the above email addresses satisfy your request, use this address.
      </p>-->
      <p><Icon name="info" size={iconDimension} />For support, reports, bugs, or feedback, please use this address.</p>
      <p><Icon name="email" size={iconDimension} />{emails.contact}</p>
      <LinkNext href={`mailto:${emails.contact}`}><Icon name="send" size={iconSendDimension} />Send an email</LinkNext>
    </article>
    <article class="article-contact">
      <h2 class="article-contact-title"><Icon name="report" size={iconDimension} />Report a violation</h2>
      <p>
        <Icon name="info" size={iconDimension} />If you encounter profiles that seem inappropriate or problematic, you can report them. For
        more details, please visit the report information page.
      </p>
      <LinkNext href="/i/contact/report"><Icon name="page" size={iconSendDimension} />Go to report page</LinkNext>
    </article>
  </div>
</MainLayout>

<style lang="scss">
  .article-contact {
    display: flex;
    flex: 1 1 25em;
    flex-direction: column;
    gap: 1.125em;
    box-sizing: border-box;
    border-block-start: thin solid var(--color-highlight);
    padding-block-start: 1.6875em;
    > p {
      display: flex;
      align-items: flex-start;
      gap: 0.625em;
      margin: 0;
      padding-inline-start: 0.5625em;
      > svg {
        min-width: max-content;
      }
      &:last-of-type {
        margin-block-end: auto;
      }
    }
  }

  .article-contact-title {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0;
    padding-inline-start: 0.4375rem;
    min-width: max-content;
    color: var(--color-highlight);
    font-size: 1.25em;
  }

  .container-contact {
    /*display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2em 2.5em;
    max-width: 60em;*/
    display: grid;
    gap: 2em;
    //
    margin-inline: auto;
    margin-block-start: 2em;
    max-width: 46em;
  }
</style>
