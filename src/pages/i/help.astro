---
import { Icon } from "astro-icon/components";
import { PLATFORM_NAME } from "astro:env/client";

import Main from "#src/layouts/Main.astro";

import LinkNext from "#src/components/LinkNext.astro";
import ListSocial from "#src/components/ListSocial.astro";

const iconDimension = "1.25em";
---

<Main title="Help">
  <h1>Need a hand?</h1>
  <div class="help-container">
    <section class="help-section">
      <hgroup>
        <h2 class="h-title"><abbr title="Frequently Asked Questions">FAQs</abbr> page</h2>
        <p class="description">
          If you have a question, take a moment to visit the <abbr title="Frequently Asked Questions">FAQs</abbr> page; it covers the most common
          topics and issues. You might find your answer there right away!
        </p>
      </hgroup>
      <LinkNext href="/i/faq" class="a-faq"><Icon name="faq" size={iconDimension} />Visit the FAQs page</LinkNext>
    </section>
    <section class="help-section">
      <hgroup>
        <h2 class="h-title">Still Need Help?</h2>
        <p class="description">Feel free to contact</p>
      </hgroup>
      <ul class="list-contact">
        <li><LinkNext href="/i/contact"><Icon name="email" size={iconDimension} />Visit the contact page</LinkNext></li>
        <!-- <li><LinkNext href="/i/contact/report"><Icon name="report" size={iconDimension} />Report a violation</LinkNext></li> -->
      </ul>
    </section>
  </div>
  <ul class="list-nav">
    <li><LinkNext href="/i/policy"><Icon name="policy" size={iconDimension} />Privacy policy</LinkNext></li>
    <li><LinkNext href="/i/terms"><Icon name="agreement" size={iconDimension} />Terms and conditions</LinkNext></li>
    <li><LinkNext href="/i/security"><Icon name="security" size={iconDimension} />Security</LinkNext></li>
    <li><LinkNext href="/i/about"><Icon name="info" size={iconDimension} />About {PLATFORM_NAME}</LinkNext></li>
  </ul>
  <div>
    <hgroup>
      <h2 class="h-title">Social media</h2>
      <p class="description">Look for <strong>{PLATFORM_NAME}</strong> in other platforms</p>
    </hgroup>
    <ListSocial class="social" />
  </div>
</Main>

<style lang="scss">
  .a-faq {
    margin-block-start: auto;
  }

  .description {
    margin-inline: auto;
    max-width: max-content;
  }

  .h-title {
    margin-block-end: 0;
    color: var(--color-highlight);
    text-align: center;
  }

  .help-container,
  .list-nav {
    margin-inline: auto;
    max-width: 61em;
  }

  .help-container {
    display: flex;
    flex-direction: column;
    gap: 2em 3em;
    margin-block-start: 1.5em;
  }

  .help-section {
    border-block-start: thin solid var(--color-highlight);
  }

  .list-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75em 1.5em;
    margin-block: auto 0;
    padding: 0;
    list-style: none;
    > li {
      flex: 1;
    }
  }

  .list-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75em 3em;
    margin-block: 2em 3em;
    border-block-start: thin solid var(--color-highlight);
    padding-inline: 0;
    padding-block: 2em 0;
    list-style: none;
    > li {
      flex: 1;
    }
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5em;
    margin: 0;
    padding: 0;
    list-style: none;
    :global(a) {
      --color-a: var(--color-3);
      --color-a-hover: var(--color-2);
      text-decoration: none;
    }
  }

  @media (width >= 40em) {
    .list-nav {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (width >= 48em) {
    .help-container {
      flex-direction: row;
    }

    .help-section {
      display: grid;
      flex: 1;
    }
  }
</style>
