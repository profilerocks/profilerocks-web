---
import { render } from "astro:content";
import ArticleLayout from "#src/layouts/Article.astro";
import { blogCollection } from "#src/lib/collections";

export async function getStaticPaths() {
  const paths = [];

  for (const post of blogCollection) {
    paths.push({
      params: { entry: post.id },
      props: { post }
    });
  }

  return paths;
}

const { post } = Astro.props;
const { Content } = await render(post); // Renders Markdown to HTML
---

<ArticleLayout title={post.data.title}>
  <hgroup>
    <h1 class="page-title">{post.data.title}</h1>
    <p class="page-description">{post.data.description}</p>
  </hgroup>
  <p class="page-meta">
    <time datetime={post.data.date.toISOString().split("T")[0]}>{post.data.date.toDateString()}</time>
    <span title="Author">{post.data.author}</span>
  </p>
  <Content />
</ArticleLayout>

<style lang="scss">
  .page-description {
    margin-inline: auto;
    max-width: max-content;
  }

  .page-meta {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    margin-block: 2em;
    border-block-end: thin solid var(--color-border);
    padding-block-end: 0.375em;
    color: var(--color-3);
  }

  .page-title {
    margin-block-end: 0;
  }
</style>
