{
  "compilerOptions": {
    "checkJs": true,
    "paths": {
      "#public/*": ["./public/*"],
      "#shared/*": ["./shared/*"],
      "#src/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "allowJs": true
  },
  "exclude": ["dist"],
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"]
}
